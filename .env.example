# Copiá este archivo a .env y completá los valores reales.
# .env nunca se commitea (ya está en .gitignore).

DB_ROOT_PASSWORD=changeme

JWT_SECRET=generar-un-secreto-largo-y-aleatorio

# Opcionales: solo se usan si probás envío de mail (alta de profesor, reset de clave)
EMAIL_USER=
EMAIL_PASSWORD=

# Opcionales: solo se usan si probás el backup automático a Backblaze B2
BACKBLAZE_KEY_ID=
BACKBLAZE_APP_KEY=
BACKBLAZE_BUCKET_ID=
